# Copy to .env in this folder (never commit .env)

JWT_SECRET=replace-with-long-random-secret-at-least-32-characters
ADMIN_USERNAME=admin

# Leave empty to use default BCrypt hash for password "password" (local dev only).
# For production, set ADMIN_PASSWORD_HASH to a BCrypt hash of your password.
# Generate: mvn test -Dtest=PasswordHashGeneratorTest
ADMIN_PASSWORD_HASH=
