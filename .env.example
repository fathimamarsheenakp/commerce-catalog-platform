# Copy to product-service/.env and api-gateway/.env (never commit real .env files)
# Generate a strong JWT secret: openssl rand -base64 48

JWT_SECRET=replace-with-long-random-secret-at-least-32-characters

# Admin login (product-service)
ADMIN_USERNAME=admin
# BCrypt hash of your password — default in application.properties matches "password"
# Generate a new hash with: cd product-service && mvn test -Dtest=PasswordHashGeneratorTest
ADMIN_PASSWORD_HASH=

# API gateway CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173
